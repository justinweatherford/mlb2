# Required for live Discord mode (not needed for ingest.py / app.py)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678

# Database
DB_PATH=kalshi_mlb.db

# Paper trading
PAPER_MODE=realistic          # realistic | optimistic
PAPER_UNITS=10                # contracts per paper position
DRY_RUN=false                 # true = parse/classify but never open positions

# Fee model (Kalshi defaults)
MAKER_FEE_RATE=0.035
TAKER_FEE_RATE=0.07
FEE_MULTIPLIER=1.0

# Signal filters
MIN_PRICE_CENTS=3
MAX_PRICE_CENTS=97
MAX_CHASE_PRICE_CENTS=85

# Logging
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ── Kalshi API (read-only market discovery) ───────────────────────────────────
# Obtain credentials from https://kalshi.com/settings/profile/api-keys
# Store the private key with \n between lines (dotenv escaping)
KALSHI_API_KEY_ID=your_api_key_id_here
KALSHI_API_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_CONTENTS_HERE\n-----END RSA PRIVATE KEY-----
KALSHI_ENV=prod               # prod | demo
KALSHI_READ_ONLY=true
